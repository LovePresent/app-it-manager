# Database
DATABASE_URL=sqlite:///./data/itam.db

# Authentik SSO
AUTHENTIK_BASE_URL=https://auth.example.com
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_REDIRECT_URI=http://localhost:9918/auth/callback
AUTHENTIK_JWKS_URL=https://auth.example.com/application/o/itam/jwks/
AUTHENTIK_TOKEN_URL=https://auth.example.com/application/o/token/
AUTHENTIK_AUTHORIZE_URL=https://auth.example.com/application/o/authorize/
AUTHENTIK_USERINFO_URL=https://auth.example.com/application/o/userinfo/

# App
SECRET_KEY=change-me-to-a-secure-random-string
CORS_ORIGINS=["http://localhost:9918","http://localhost:3000"]
QR_BASE_URL=http://localhost:9918
ASSET_TAG_PREFIX=IT
