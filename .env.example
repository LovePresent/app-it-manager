# Database
DATABASE_URL=sqlite:///./data/itam.db

# Authentik SSO
AUTHENTIK_BASE_URL=https://auth.cqv.kr
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_REDIRECT_URI=https://dev.cqv.kr/manage/it/api/v1/auth/callback
AUTHENTIK_JWKS_URL=https://auth.cqv.kr/application/o/itam/jwks/
AUTHENTIK_TOKEN_URL=https://auth.cqv.kr/application/o/token/
AUTHENTIK_AUTHORIZE_URL=https://auth.cqv.kr/application/o/authorize/
AUTHENTIK_USERINFO_URL=https://auth.cqv.kr/application/o/userinfo/

# App
SECRET_KEY=change-me-to-a-secure-random-string
CORS_ORIGINS=["https://dev.cqv.kr"]
FRONTEND_URL=https://dev.cqv.kr/manage/it
QR_BASE_URL=https://dev.cqv.kr/manage/it
ASSET_TAG_PREFIX=IT

# Admin accounts (auto-assigned admin role on first login)
ADMIN_EMAILS=["it.j@cqv.kr"]
